# Path to whisper.cpp binary (the `main` or `whisper-cli` executable, depending on version).
# On Windows: e.g. C:\tools\whisper.cpp\main.exe
WHISPER_CPP_BIN=

# Path to the whisper.cpp model file (.bin). Recommended: ggml-base.en.bin or ggml-small.en.bin.
# Download from https://huggingface.co/ggerganov/whisper.cpp
WHISPER_CPP_MODEL=

# Together AI key for the LLM preset picker (Llama-4-Maverick).
# Get one at https://api.together.xyz
TOGETHER_API_KEY=

# Optional: ffmpeg binary path. Defaults to "ffmpeg" on PATH.
FFMPEG_BIN=ffmpeg
