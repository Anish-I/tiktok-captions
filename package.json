{
  "name": "tiktok-captions",
  "version": "0.1.0",
  "description": "Vibe-driven TikTok-style subtitle generator. Natural-language prompt -> styled .ass/.srt subtitle file.",
  "type": "module",
  "bin": {
    "tiktok-caps": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "subtitles",
    "captions",
    "tiktok",
    "ass",
    "srt",
    "whisper",
    "ffmpeg"
  ],
  "author": "Anish",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "openai": "^4.79.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "playwright": "^1.60.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
